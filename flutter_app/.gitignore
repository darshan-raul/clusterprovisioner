# ─── Flutter / Dart ────────────────────────────────────────────────────────
# Build output
build/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages

# pub cache
.pub-cache/
.pub/

# Generated files
*.g.dart
*.freezed.dart

# ─── Sensitive / Environment ───────────────────────────────────────────────
# Never commit real config values
# config.dart uses String.fromEnvironment() so the file itself is safe to commit,
# but add any local override files here if you ever create them:
lib/config.local.dart
*.env
.env
.env.*

# dart-define files (sometimes used as JSON for CI)
dart_defines/
*.dart-define.json

# ─── IDE ───────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.ipr
*.iws

# ─── macOS ─────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ─── iOS ───────────────────────────────────────────────────────────────────
**/ios/.symlinks/
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Flutter.podspec
**/ios/Flutter/app.flx
**/ios/Flutter/app.zip
**/ios/Flutter/flutter_assets/
**/ios/ServiceDefinitions.json
**/ios/Runner/GeneratedPluginRegistrant.*
**/ios/Pods/

# ─── Android ───────────────────────────────────────────────────────────────
**/android/**/gradle-wrapper.jar
**/android/.gradle
**/android/captures/
**/android/gradlew
**/android/gradlew.bat
**/android/local.properties
**/android/**/GeneratedPluginRegistrant.java
**/android/key.properties
*.jks

# ─── Web ───────────────────────────────────────────────────────────────────
# flutter_bootstrap.js and flutter.js are generated at build time
web/flutter_bootstrap.js
web/flutter_service_worker.js
web/flutter.js
web/version.json
# But keep web/index.html, web/manifest.json, web/favicon.png, web/icons/

# ─── Coverage / Tests ──────────────────────────────────────────────────────
coverage/
*.lcov

# ─── Misc ──────────────────────────────────────────────────────────────────
*.log
pubspec.lock    # Optional: commit this for apps (remove line to track it)
